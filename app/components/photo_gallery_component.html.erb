<section class="mb-16"
         data-controller="photo-gallery-filter-component photo-gallery-lightbox-component"
         data-photo-gallery-filter-component-images-value="<%= gallery_data.to_json %>"
         data-photo-gallery-filter-component-table-of-contents-component-outlet="[data-controller~='table-of-contents-component']"
         data-photo-gallery-lightbox-component-photo-gallery-filter-component-outlet="[data-controller~='photo-gallery-filter-component']">

  <%# ── Intro: the latest frame + the year filter, the gallery's "filters" anchor ─ %>
  <div id="garden-filters">
    <%# Hero: the latest frame, presented as the most recent log entry %>
    <% if latest %>
      <button type="button"
              data-action="click->photo-gallery-lightbox-component#open"
              data-photo-gallery-lightbox-component-index-param="<%= latest[:idx] %>"
              class="gallery-hero relative block w-full overflow-hidden rounded-box bg-base-300
                     text-left cursor-zoom-in group
                     focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              aria-label="Open the latest photo<%= " from #{latest[:date]}" if latest[:date] %>">
        <%= image_tag latest[:path],
                      loading: "eager",
                      fetchpriority: "high",
                      decoding: "async",
                      alt: latest[:basename],
                      class: "h-[52vh] min-h-[20rem] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" %>
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-base-300/90 via-base-300/20 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 p-5 sm:p-8">
          <p class="font-mono text-primary text-sm mb-2">
            $ tail -f garden.log<span class="gallery-cursor">_</span>
          </p>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-base-content">The garden log</h1>
          <p class="mt-3 font-mono text-xs text-base-content/70">
            <span class="text-secondary"><%= images.length %></span> frames · <%= span_label %>
            <% if latest[:date] %><span class="text-base-content/50"> · last entry <%= latest[:date] %></span><% end %>
          </p>
        </div>
      </button>
    <% end %>

    <%# Filter bar: a single growing year (single-select) × any months (multi-select) %>
    <div class="mt-8 mb-8 space-y-2">
      <div class="gallery-filter-row flex items-center gap-2 sm:flex-wrap" role="group" aria-label="Filter photos by year">
        <span class="font-mono text-xs text-base-content/50 mr-1">year:</span>
        <button type="button"
                data-photo-gallery-filter-component-target="chip"
                data-action="click->photo-gallery-filter-component#filter"
                data-photo-gallery-filter-component-year-param="all"
                aria-pressed="true"
                class="gallery-chip btn btn-sm sm:btn-xs btn-primary font-mono">
          all <%= frame_count(images.length) %>
        </button>
        <% chapters.each do |year, imgs| %>
          <%= tooltip_tag months_label(imgs) do %>
            <button type="button"
                    data-photo-gallery-filter-component-target="chip"
                    data-action="click->photo-gallery-filter-component#filter"
                    data-photo-gallery-filter-component-year-param="<%= year %>"
                    aria-pressed="false"
                    class="gallery-chip btn btn-sm sm:btn-xs font-mono">
              <% from, to = season_range(imgs) %>
              <span class="season-bar inline-block w-1.5 h-1.5 rounded-full mr-1.5 align-middle"
                    data-from="<%= from %>" data-to="<%= to %>"></span>
              <%= year %> <%= frame_count(imgs.length) %>
            </button>
          <% end %>
        <% end %>
      </div>

      <div class="gallery-filter-row flex items-center gap-2 sm:flex-wrap" role="group" aria-label="Filter photos by month">
        <span class="font-mono text-xs text-base-content/50 mr-1">month:</span>
        <button type="button"
                data-photo-gallery-filter-component-target="chip"
                data-action="click->photo-gallery-filter-component#toggleMonth"
                data-photo-gallery-filter-component-month-param="all"
                aria-pressed="true"
                class="gallery-chip btn btn-sm sm:btn-xs btn-primary font-mono">
          all <%= frame_count(images.length) %>
        </button>
        <% months_present.each do |m| %>
          <%= tooltip_tag years_for_month(m), position: "bottom" do %>
            <button type="button"
                    data-photo-gallery-filter-component-target="chip"
                    data-action="click->photo-gallery-filter-component#toggleMonth"
                    data-photo-gallery-filter-component-month-param="<%= m %>"
                    aria-pressed="false"
                    class="gallery-chip btn btn-sm sm:btn-xs font-mono">
              <span class="season-dot inline-block w-1.5 h-1.5 rounded-full mr-1.5 align-middle"
                    data-season="<%= season(m) %>"></span>
              <%= MONTHS[m] %> <%= frame_count(entries_by_month[m].length) %>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Jump-to-year sidebar (reused TOC; only under the "all" filter) ────────── %>
  <div data-photo-gallery-filter-component-target="toc">
    <%= table_of_contents_tag(sections: year_sections) %>
  </div>

  <%# ── Year chapters ────────────────────────────────────────────────────────── %>
  <% chapters.each_with_index do |(year, imgs), chapter_index| %>
    <div id="garden-<%= year %>"
         data-photo-gallery-filter-component-target="chapter" data-year="<%= year %>" class="mb-12">
      <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1 mb-1">
        <h2 class="font-mono text-base text-base-content">
          <span class="text-base-content/40">~/garden/</span><span class="text-secondary font-semibold"><%= year %></span>
        </h2>
        <p class="font-mono text-xs text-base-content/60">
          <span data-chapter-count><%= imgs.length %></span> frames<% if month_range(imgs) %> · <%= month_range(imgs) %><% end %>
        </p>
      </div>
      <% from, to = season_range(imgs) %>
      <div class="season-bar h-px w-full rounded-full mb-4"
           data-from="<%= from %>" data-to="<%= to %>"></div>

      <%# ── Optional log: what happened this year ──────────────────────────────── %>
      <% year_notes = notes_for(year) %>
      <% if year_notes.any? %>
        <div class="mb-4 space-y-2">
          <% year_notes.each do |note| %>
            <div class="font-mono text-sm">
              <p class="flex flex-wrap items-baseline gap-x-2">
                <span aria-hidden="true"><%= LOG_ICON %></span>
                <time class="text-base-content/50 text-xs" datetime="<%= note[:date] %>"><%= note[:date].strftime("%Y-%m-%d") %></time>
                <span class="font-semibold text-base-content"><%= note[:title] %></span>
              </p>
              <p class="pl-6 mt-1 text-xs leading-relaxed text-base-content/70">
                <%= note[:body] %>
                <% if note[:tag].present? %><span class="text-secondary">#<%= note[:tag] %></span><% end %>
              </p>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 auto-rows-[7rem] sm:auto-rows-[9rem] md:auto-rows-[10rem] gap-3">
        <% imgs.each_with_index do |img, img_index| %>
          <%# First row of the newest chapter sits at the fold: load it up front,
              but at default priority so it doesn't compete with the hero (LCP). %>
          <% above_fold = chapter_index.zero? && img_index < 4 %>
          <button type="button"
                  data-action="click->photo-gallery-lightbox-component#open"
                  data-photo-gallery-filter-component-target="tile"
                  data-photo-gallery-lightbox-component-index-param="<%= img[:idx] %>"
                  data-month="<%= img[:month] %>"
                  class="skeleton relative block overflow-hidden rounded-box bg-base-200 group cursor-zoom-in
                         focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                  aria-label="Open photo<%= " from #{img[:date]}" if img[:date] %>">
            <%# The image paints over the .skeleton placeholder once decoded.
                Visibility is left to the browser (no JS opacity gating) so a
                loaded tile can't be hidden by a later Turbo re-render/morph. %>
            <%= image_tag img[:path],
                          loading: above_fold ? "eager" : "lazy",
                          decoding: "async",
                          alt: img[:basename],
                          class: "gallery-tile w-full h-full object-cover transition duration-500 group-hover:scale-105" %>
            <% if img[:date] %>
              <span class="pointer-events-none absolute bottom-2 left-2 inline-flex items-center gap-1.5
                           px-1.5 py-0.5 rounded bg-base-100/85 text-base-content font-mono text-[10px] tracking-tight
                           opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100
                           transition-opacity duration-200">
                <span class="season-dot inline-block w-1.5 h-1.5 rounded-full"
                      data-season="<%= img[:season] %>"></span>
                <%= img[:date] %>
              </span>
            <% end %>
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Lightbox ─────────────────────────────────────────────────────────────── %>
  <dialog data-photo-gallery-lightbox-component-target="dialog"
          data-action="keydown->photo-gallery-lightbox-component#keydown"
          class="modal">
    <div class="modal-box flex flex-col w-full p-0 bg-base-100 overflow-hidden select-none
                max-w-none h-[100dvh] max-h-[100dvh] rounded-none
                sm:max-w-6xl sm:h-auto sm:max-h-[calc(100dvh-5em)] sm:rounded-box">
      <div class="relative flex-1 min-h-0 sm:flex-none bg-base-300/40">
        <img data-photo-gallery-lightbox-component-target="image"
             data-action="mousedown->photo-gallery-lightbox-component#preventSelect click->photo-gallery-lightbox-component#toggleFit"
             class="block w-full h-full sm:h-auto max-h-[100dvh] sm:max-h-[80vh]
                    object-contain object-center bg-black/5 cursor-pointer select-none"
             alt="" />

        <%# Prev / next / close share button + icon chrome — only the action, label,
            position and icon differ, so render them from one list. %>
        <% [
             { action: "prev",  label: "Previous photo", position: "left-3 top-1/2 -translate-y-1/2",  icon: "chevron-left" },
             { action: "next",  label: "Next photo",     position: "right-3 top-1/2 -translate-y-1/2", icon: "chevron-right" },
             { action: "close", label: "Close gallery",  position: "top-3 right-3",                    icon: "x" }
           ].each do |btn| %>
          <button type="button"
                  data-action="click->photo-gallery-lightbox-component#<%= btn[:action] %>"
                  aria-label="<%= btn[:label] %>"
                  class="btn btn-circle btn-ghost bg-base-100/80 hover:bg-base-100 absolute <%= btn[:position] %>">
            <%= lucide_icon btn[:icon], class: "w-5 h-5" %>
          </button>
        <% end %>
      </div>

      <div class="flex items-center justify-between gap-3 px-5 py-3 border-t border-base-300 font-mono text-xs">
        <span class="inline-flex items-center gap-2 min-w-0 text-base-content/70">
          <span data-photo-gallery-lightbox-component-target="dot" class="season-dot tooltip tooltip-right inline-block w-2 h-2 rounded-full shrink-0"></span>
          <span data-photo-gallery-lightbox-component-target="caption" class="truncate"></span>
        </span>
        <span class="text-base-content/40 hidden sm:inline">← → to navigate · esc to close</span>
        <span class="inline-flex shrink-0 items-center gap-3">
          <button type="button"
                  data-action="click->photo-gallery-lightbox-component#toggleFit"
                  data-photo-gallery-lightbox-component-target="fitToggle"
                  aria-pressed="false"
                  aria-label="Fill the screen with this photo"
                  class="text-base-content/40 transition-colors hover:text-primary focus-visible:text-primary focus:outline-none">
            <span class="text-base-content/25">--</span><span data-photo-gallery-lightbox-component-target="fitLabel">fit</span>
          </button>
          <span data-photo-gallery-lightbox-component-target="counter" class="text-secondary"></span>
        </span>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</section>
