<div data-controller="table-of-contents-component" aria-label="Page sections">
  <aside class="hidden 2xl:block fixed right-8 top-1/2 -translate-y-1/2 z-20 w-56">
    <p class="font-mono text-xs tracking-wider text-base-content/50 mb-3">
      <span class="text-primary">$</span> <span class="text-base-content/80">go</span><span class="text-base-content/40">to</span>
    </p>
    <ul class="space-y-2 font-mono text-sm border-l border-base-300 pl-3">
      <% sections.each do |section| %>
        <li>
          <a href="#<%= section[:id] %>"
             data-table-of-contents-component-target="link"
             data-section="<%= section[:id] %>"
             data-action="click->table-of-contents-component#onLinkClick"
             class="link link-hover text-base-content/60 transition-colors">
            <%= section[:label] %>
          </a>
          <% if section[:children].present? %>
            <ul class="mt-1.5 ml-2 space-y-1.5 border-l border-base-300/60 pl-3">
              <% section[:children].each do |child| %>
                <li>
                  <a href="#<%= child[:id] %>"
                     data-table-of-contents-component-target="link"
                     data-section="<%= child[:id] %>"
                     data-action="click->table-of-contents-component#onLinkClick"
                     class="link link-hover text-base-content/60 text-xs transition-colors">
                    <%= child[:label] %>
                  </a>
                </li>
              <% end %>
            </ul>
          <% end %>
        </li>
      <% end %>
    </ul>
  </aside>

  <div class="2xl:hidden fixed bottom-24 right-6 z-30 dropdown dropdown-top dropdown-end">
    <label tabindex="0"
           class="btn btn-circle btn-primary shadow-lg"
           aria-label="Open table of contents">
      <%= lucide_icon "list", class: "h-5 w-5" %>
    </label>
    <ul tabindex="0"
        class="toc-menu menu dropdown-content mb-3 p-2 shadow bg-base-200 rounded-box w-60 font-mono max-h-[70vh] overflow-y-auto">
      <li class="menu-title text-xs">
        <span><span class="text-primary">$</span> <span class="text-base-content/80">go</span><span class="text-base-content/40">to</span></span>
      </li>
      <% sections.each do |section| %>
        <li>
          <a href="#<%= section[:id] %>"
             data-table-of-contents-component-target="link"
             data-section="<%= section[:id] %>"
             data-action="click->table-of-contents-component#onLinkClick"><%= section[:label] %></a>
          <% if section[:children].present? %>
            <ul>
              <% section[:children].each do |child| %>
                <li>
                  <a href="#<%= child[:id] %>"
                     data-table-of-contents-component-target="link"
                     data-section="<%= child[:id] %>"
                     data-action="click->table-of-contents-component#onLinkClick"
                     class="text-xs"><%= child[:label] %></a>
                </li>
              <% end %>
            </ul>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</div>
