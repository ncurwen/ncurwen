<div class="timeline-track">
  <% last_index = positions.length - 1 %>
  <% positions.each_with_index do |position, index| %>
    <% node_modifier = if index.zero?
                         "timeline-node--bloom"
                       elsif index == last_index
                         "timeline-node--seed"
                       end %>
    <article id="<%= WorkHistoryComponent.anchor(position[:company]) %>" class="timeline-entry scroll-mt-24">
      <span aria-hidden="true" class="timeline-node <%= node_modifier %>"></span>

      <header class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
        <h3 class="card-title font-mono"><%= position[:company] %></h3>
        <span class="font-mono text-sm text-primary"><%= position[:period] %></span>
      </header>
      <% if position[:location].present? %>
        <p class="font-mono text-xs text-base-content/60 mt-0.5"><%= position[:location] %></p>
      <% end %>
      <% if position[:summary].present? %>
        <p class="text-base-content/80 mt-2 max-w-2xl"><%= position[:summary] %></p>
      <% end %>

      <div class="timeline-roles mt-4 space-y-4">
        <% Array(position[:roles]).each do |role| %>
          <div class="timeline-role">
            <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
              <h4 class="font-bold"><%= role[:title] %></h4>
              <% if role[:period].present? %>
                <span class="font-mono text-xs text-base-content/60"><%= role[:period] %></span>
              <% end %>
            </div>
            <% if role[:bullets].present? %>
              <ul class="list-disc list-outside ml-5 mt-2 space-y-1 text-base-content/80 text-sm">
                <% role[:bullets].each do |bullet| %>
                  <li><%= bullet %></li>
                <% end %>
              </ul>
            <% end %>
          </div>
        <% end %>
      </div>
    </article>
  <% end %>
</div>
