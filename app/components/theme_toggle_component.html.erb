<%= tooltip_tag "Toggle theme", position: "left" do %>
  <label class="swap swap-rotate btn btn-ghost btn-circle" aria-label="Toggle theme">
    <%# Hidden checkbox controls the swap state; checked = dark theme. Initial
        state comes from the cookie so it matches the server-rendered theme. %>
    <input type="checkbox"
           <%= "checked" unless light_mode? %>
           data-controller="theme-toggle-component"
           data-action="change->theme-toggle-component#toggle" />

    <%# swap-off shows in light mode, swap-on in dark mode. %>
    <%= lucide_icon "sun", class: "swap-off h-5 w-5" %>
    <%= lucide_icon "moon", class: "swap-on h-5 w-5" %>
  </label>
<% end %>
