<% content_for :title, "Nick Curwen — software developer, tech enthusiast, gardener" %>

<section class="hero py-12 md:py-16">
  <div class="hero-content text-center max-w-3xl">
    <div>
      <%= cli_prompt_tag("whoami", classes: "mb-4") %>
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8 text-center md:text-left">
        <div class="avatar shrink-0">
          <div class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 shadow-lg">
            <%= image_tag "me.jpeg", alt: "Nick Curwen" %>
          </div>
        </div>
        <div>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-3">
            Hi, I'm Nick Curwen.
          </h1>
          <p class="text-xl md:text-2xl mb-1">I'm a</p>
          <p class="font-mono text-2xl md:text-4xl text-primary typewriter-caret inline-block text-left whitespace-nowrap min-w-[20ch]"
             data-controller="typewriter"
             data-typewriter-phrases-value='["software developer.","tech enthusiast.","gardener."]'>
            <span data-typewriter-target="text">software developer.</span>
          </p>
        </div>
      </div>
      <p class="mt-8 text-base-content/80 text-lg max-w-xl mx-auto">
        I love building things with technology, and I also enjoy growing green things whenever my laptop shuts down.
        Come by and check out what I've been up to, or just give me a shout.
      </p>

      <div class="flex flex-wrap gap-3 justify-center mt-8">
        <%= link_to "see experience →", experience_path,
                    class: "btn btn-primary font-mono",
                    data: { turbo_action: "advance" } %>
        <%= link_to "say hello", contact_path,
                    class: "btn btn-outline font-mono",
                    data: { turbo_action: "advance" } %>
      </div>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-4 pb-20">
  <div class="grid gap-6 md:grid-cols-3">
    <%= link_to experience_path,
                class: "card group bg-base-200 border border-base-300 hover:bg-base-300 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl inline-block origin-left transition-transform duration-200 group-hover:scale-110">💻</div>
        <h2 class="card-title font-mono transition-colors group-hover:text-primary">experience</h2>
        <p class="text-base-content/70">Over a decade of full-stack Rails, AWS and data processing.</p>
      </div>
    <% end %>

    <%= link_to garden_path,
                class: "card group bg-base-200 border border-base-300 hover:bg-base-300 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl inline-block origin-left transition-transform duration-200 group-hover:scale-110">🌱</div>
        <h2 class="card-title font-mono transition-colors group-hover:text-primary">garden</h2>
        <p class="text-base-content/70">Notes from the veg patch. Seasonal, honest, occasionally muddy.</p>
      </div>
    <% end %>

    <%= link_to contact_path,
                class: "card group bg-base-200 border border-base-300 hover:bg-base-300 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl inline-block origin-left transition-transform duration-200 group-hover:scale-110">✉️</div>
        <h2 class="card-title font-mono transition-colors group-hover:text-primary">contact</h2>
        <p class="text-base-content/70">Hiring, collaborating, or just curious — I'd like to hear from you.</p>
      </div>
    <% end %>
  </div>
</section>
