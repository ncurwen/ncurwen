<% content_for :title, "Nick Curwen — senior software developer, tech enthusiast, gardener" %>

<section class="hero py-16 md:py-24">
  <div class="hero-content text-center max-w-3xl">
    <div>
      <p class="font-mono text-primary text-sm mb-4">$ whoami</p>
      <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8 text-center md:text-left">
        <div class="avatar shrink-0">
          <div class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
            <%= image_tag "me.jpeg", alt: "Nick Curwen" %>
          </div>
        </div>
        <div>
          <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-4">
            Hi, I'm Nick Curwen.
          </h1>
          <p class="text-xl md:text-2xl mb-2">I'm a</p>
          <p class="font-mono text-2xl md:text-4xl text-primary typewriter-caret"
             data-controller="typewriter"
             data-typewriter-phrases-value='["software developer.","tech enthusiast.","gardener."]'>
            <span data-typewriter-target="text">software developer.</span>
          </p>
        </div>
      </div>
      <p class="mt-8 text-base-content/80 text-lg max-w-xl mx-auto">
        I love building things with technology, and I enjoy growing tomatoes whenever my laptop shuts down.
        Drop in to see what I've worked on, or get in touch.
      </p>

      <div class="flex flex-wrap gap-3 justify-center mt-8">
        <%= link_to "see experience →", experience_path,
                    class: "btn btn-primary font-mono",
                    data: { turbo_action: "advance" } %>
        <%= link_to "say hello", contact_path,
                    class: "btn btn-outline font-mono",
                    data: { turbo_action: "advance" } %>
      </div>
    </div>
  </div>
</section>

<section class="max-w-5xl mx-auto px-4 pb-20">
  <div class="grid gap-6 md:grid-cols-3">
    <%= link_to experience_path,
                class: "card bg-base-200 hover:bg-base-300 transition-colors",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl">💻</div>
        <h2 class="card-title font-mono">experience</h2>
        <p class="text-base-content/70">A decade of Rails, AWS and ETL — plus agilepanda.dev.</p>
      </div>
    <% end %>

    <%= link_to garden_path,
                class: "card bg-base-200 hover:bg-base-300 transition-colors",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl">🌱</div>
        <h2 class="card-title font-mono">garden</h2>
        <p class="text-base-content/70">Notes from the veg patch. Seasonal, honest, occasionally muddy.</p>
      </div>
    <% end %>

    <%= link_to contact_path,
                class: "card bg-base-200 hover:bg-base-300 transition-colors",
                data: { turbo_action: "advance" } do %>
      <div class="card-body">
        <div class="text-3xl">✉️</div>
        <h2 class="card-title font-mono">contact</h2>
        <p class="text-base-content/70">Hiring, collaborating, or just curious — I'd like to hear from you.</p>
      </div>
    <% end %>
  </div>
</section>
