<% content_for :title, "Garden — Nick Curwen" %>

<section class="max-w-5xl mx-auto px-4 py-12">
  <header class="mb-10">
    <%= render "shared/cli_prompt", text: "tail -n 4 garden.log", classes: "mb-1" %>
    <h1 class="text-3xl md:text-4xl font-bold">Garden notes</h1>
    <p class="mt-2 text-base-content/70">
      A small allotment journal. Mostly so I can remember what I planted where.
    </p>
  </header>

  <%= render PhotoGalleryComponent.new(images: SiteData.garden_images) %>

  <div class="mb-4">
    <%= render "shared/cli_prompt", text: "cat garden.log" %>
  </div>

  <%= render TimelineComponent.new(entries: SiteData.garden_notes[:entries]) %>
</section>
