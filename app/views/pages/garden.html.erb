<% content_for :title, "Garden — Nick Curwen" %>
<% entries = SiteData.garden_notes[:entries] %>
<% images = SiteData.garden_images %>

<section class="max-w-5xl mx-auto px-4 py-12">
  <header class="mb-10">
    <p class="font-mono text-primary text-sm mb-1">$ tail -n 4 garden.log</p>
    <h1 class="text-3xl md:text-4xl font-bold">Garden notes</h1>
    <p class="mt-2 text-base-content/70">
      A small allotment journal. Mostly so I can remember what I planted where.
    </p>
  </header>

  <% if images.any? %>
    <section class="mb-12">
      <p class="font-mono text-primary text-sm mb-3">$ ls images/garden</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        <% images.each do |path| %>
          <a href="<%= asset_path(path) %>" target="_blank" rel="noopener"
             class="block aspect-square overflow-hidden rounded-box bg-base-200 group">
            <%= image_tag path,
                          loading: "lazy",
                          alt: File.basename(path, ".*"),
                          class: "w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" %>
          </a>
        <% end %>
      </div>
    </section>
  <% end %>

  <ul class="timeline timeline-vertical timeline-snap-icon timeline-compact max-w-3xl">
    <% entries.each_with_index do |entry, i| %>
      <li>
        <% if i > 0 %><hr class="bg-primary/40" /><% end %>
        <div class="timeline-middle">
          <span class="inline-flex w-6 h-6 rounded-full bg-primary text-primary-content items-center justify-center text-xs">🌱</span>
        </div>
        <div class="timeline-end timeline-box bg-base-200 border-base-300 my-2">
          <time class="font-mono text-xs text-base-content/60" datetime="<%= entry[:date] %>">
            <%= entry[:date].strftime("%Y-%m-%d") %>
          </time>
          <h3 class="font-bold text-lg mt-1"><%= entry[:title] %></h3>
          <p class="text-base-content/80 mt-1"><%= entry[:body] %></p>
          <% if entry[:tag].present? %>
            <span class="badge badge-soft badge-sm font-mono mt-3">#<%= entry[:tag] %></span>
          <% end %>
        </div>
        <% if i < entries.length - 1 %><hr class="bg-primary/40" /><% end %>
      </li>
    <% end %>
  </ul>
</section>
