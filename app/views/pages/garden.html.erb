<% content_for :title, "Garden — Nick Curwen" %>
<% entries = SiteData.garden_notes[:entries] %>
<% images = SiteData.garden_images %>
<% gallery_data = images.map { |img| { url: asset_path(img[:path]), date: img[:date], basename: img[:basename] } } %>
<% years = images.map { |i| i[:date]&.slice(0, 4) }.compact.uniq.sort.join("–") %>

<section class="max-w-5xl mx-auto px-4 py-12">
  <header class="mb-10">
    <p class="font-mono text-primary text-sm mb-1">$ tail -n 4 garden.log</p>
    <h1 class="text-3xl md:text-4xl font-bold">Garden notes</h1>
    <p class="mt-2 text-base-content/70">
      A small allotment journal. Mostly so I can remember what I planted where.
    </p>
  </header>

  <% if images.any? %>
    <section class="mb-16" data-controller="gallery" data-gallery-images-value="<%= gallery_data.to_json %>">
      <div class="flex flex-wrap items-baseline justify-between gap-2 mb-4">
        <p class="font-mono text-primary text-sm">$ ls images/garden/</p>
        <p class="font-mono text-xs text-base-content/60">
          <%= images.length %> photos<% if years.present? %> · <%= years %><% end %>
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 auto-rows-[7rem] sm:auto-rows-[9rem] md:auto-rows-[10rem] gap-3">
        <% images.each_with_index do |img, i| %>
          <% feature = (i == 0) %>
          <button type="button"
                  data-action="click->gallery#open"
                  data-gallery-index-param="<%= i %>"
                  class="relative block overflow-hidden rounded-box bg-base-200 group cursor-zoom-in
                         focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2
                         <%= 'sm:col-span-2 sm:row-span-2' if feature %>"
                  aria-label="Open photo<%= " from #{img[:date]}" if img[:date] %>">
            <%= image_tag img[:path],
                          loading: "lazy",
                          alt: img[:basename],
                          class: "w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" %>
            <% if img[:date] %>
              <span class="pointer-events-none absolute bottom-2 left-2 px-1.5 py-0.5 rounded
                           bg-base-100/85 text-base-content font-mono text-[10px] tracking-tight
                           opacity-0 group-hover:opacity-100 group-focus-visible:opacity-100
                           transition-opacity duration-200">
                <%= img[:date] %>
              </span>
            <% end %>
            <% if feature %>
              <span class="pointer-events-none absolute top-2 left-2 px-2 py-0.5 rounded-full
                           bg-primary text-primary-content font-mono text-[10px] uppercase tracking-wider">
                head
              </span>
            <% end %>
          </button>
        <% end %>
      </div>

      <dialog data-gallery-target="dialog"
              data-action="keydown->gallery#keydown"
              class="modal">
        <div class="modal-box max-w-6xl w-full p-0 bg-base-100 overflow-hidden">
          <div class="relative bg-base-300/40">
            <img data-gallery-target="image"
                 class="block w-full max-h-[80vh] object-contain bg-black/5"
                 alt="" />

            <button type="button"
                    data-action="click->gallery#prev"
                    aria-label="Previous photo"
                    class="btn btn-circle btn-ghost bg-base-100/80 hover:bg-base-100
                           absolute left-3 top-1/2 -translate-y-1/2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </button>

            <button type="button"
                    data-action="click->gallery#next"
                    aria-label="Next photo"
                    class="btn btn-circle btn-ghost bg-base-100/80 hover:bg-base-100
                           absolute right-3 top-1/2 -translate-y-1/2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>

            <button type="button"
                    data-action="click->gallery#close"
                    aria-label="Close gallery"
                    class="btn btn-circle btn-ghost bg-base-100/80 hover:bg-base-100
                           absolute top-3 right-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>

          <div class="flex items-center justify-between px-5 py-3 border-t border-base-300 font-mono text-xs">
            <span data-gallery-target="caption" class="text-base-content/70"></span>
            <span class="text-base-content/40 hidden sm:inline">← → to navigate · esc to close</span>
            <span data-gallery-target="counter" class="text-primary"></span>
          </div>
        </div>
        <form method="dialog" class="modal-backdrop">
          <button>close</button>
        </form>
      </dialog>
    </section>
  <% end %>

  <div class="mb-4">
    <p class="font-mono text-primary text-sm">$ cat garden.log</p>
  </div>

  <ul class="timeline timeline-vertical timeline-snap-icon timeline-compact max-w-3xl">
    <% entries.each_with_index do |entry, i| %>
      <li>
        <% if i > 0 %><hr class="bg-primary/40" /><% end %>
        <div class="timeline-middle">
          <span class="inline-flex w-7 h-7 rounded-full bg-primary text-primary-content ring-2 ring-primary/20 ring-offset-2 ring-offset-base-100 items-center justify-center text-xs">🌱</span>
        </div>
        <div class="timeline-end timeline-box bg-base-200 border-base-300 my-2">
          <time class="font-mono text-xs text-base-content/60" datetime="<%= entry[:date] %>">
            <%= entry[:date].strftime("%Y-%m-%d") %>
          </time>
          <h3 class="font-bold text-lg mt-1"><%= entry[:title] %></h3>
          <p class="text-base-content/80 mt-1"><%= entry[:body] %></p>
          <% if entry[:tag].present? %>
            <span class="badge badge-soft badge-sm font-mono mt-3">#<%= entry[:tag] %></span>
          <% end %>
        </div>
        <% if i < entries.length - 1 %><hr class="bg-primary/40" /><% end %>
      </li>
    <% end %>
  </ul>
</section>
