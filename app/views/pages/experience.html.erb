<% content_for :title, "Experience — Nick Curwen" %>

<% positions = SiteData.fetch(:work_history) %>
<% work_children = positions.map do |p|
    { id: WorkHistoryComponent.anchor(p[:company]), label: p[:company] }
  end %>

<%= table_of_contents_tag(
            sections: [
              { id: "experience",       label: "Experience" },
              { id: "featured",  label: "Featured project" },
              { id: "skills",    label: "Skills" },
              { id: "work",      label: "Work experience", children: work_children },
              { id: "education", label: "Education" }
            ]) %>

<section class="max-w-4xl mx-auto px-4 py-12 space-y-16">
  <header id="experience" class="scroll-mt-24">
    <%= cli_prompt_tag("cat resume.txt", classes: "mb-1") %>
    <h1 class="text-4xl md:text-5xl font-bold">Experience</h1>
    <p class="mt-3 text-base-content/70 max-w-2xl">
      <%= pluralize(years_experience, "year") %> building software — full-stack Rails,
      data pipelines and AWS infrastructure — for an enterprise R&amp;D shop and a
      handful of smaller teams.
    </p>
    <p class="mt-4 font-mono text-sm text-base-content/60 flex flex-wrap items-center gap-x-2 gap-y-1">
      <span class="text-primary"><%= years_experience %> yrs</span>
      <span aria-hidden="true" class="text-base-content/30">·</span>
      <span>full-stack Rails</span>
      <span aria-hidden="true" class="text-base-content/30">·</span>
      <span>data &amp; AWS</span>
      <span aria-hidden="true" class="text-base-content/30">·</span>
      <span>London, ON</span>
    </p>
  </header>

  <section id="featured" class="scroll-mt-24">
    <%= section_heading_tag(command: "ls projects/", title: "Featured project", title_class: "mb-4") %>

    <article class="card card-lg bg-base-200 border border-primary/40 shadow-sm hover:shadow-md transition-shadow">
      <div class="card-body">
        <div class="flex items-start justify-between gap-3">
          <h3 class="card-title font-mono items-center">
            <%= image_tag "agile-panda.svg", alt: "AgilePanda logo", class: "mb-5 mr-5 w-10 h-10 shrink-0", loading: "lazy" %>
            AgilePanda
          </h3>
          <span class="badge badge-primary badge-sm">featured</span>
        </div>

        <p class="text-base-content/80">
          Lightweight agile tooling for small product teams who want flow without ceremony.
        </p>

        <ul class="mt-2 space-y-2">
          <% {
               "plan"  => "Planning poker — estimate together, reveal at once.",
               "retro" => "Retrospectives — surface what worked and what's next.",
               "pick"  => "Pick lists — decide at random or by quick vote."
             }.each do |command, description| %>
            <li class="flex items-start gap-2 sm:gap-3">
              <span aria-hidden="true" class="text-primary font-mono select-none mt-0.5">▸</span>
              <span class="font-mono text-primary shrink-0 w-12"><%= command %></span>
              <span class="text-base-content/80"><%= description %></span>
            </li>
          <% end %>
        </ul>

        <p class="mt-1 border-l-2 border-primary/40 pl-3 text-sm text-base-content/70">
          <span aria-hidden="true" class="font-mono text-primary">⟲</span>
          Syncs with Jira — pulls stories from your sprint and writes estimates back. No copy-paste.
        </p>

        <div class="flex flex-wrap gap-1 pt-2">
          <% %w[Rails Hotwire Tailwind DaisyUI].each do |tech| %>
            <span class="badge badge-soft badge-sm font-mono"><%= tech %></span>
          <% end %>
        </div>

        <div class="card-actions justify-end pt-2">
          <a href="https://agilepanda.dev" target="_blank" rel="noopener"
             class="btn btn-sm btn-primary font-mono">
            visit&nbsp;→
          </a>
        </div>
      </div>
    </article>
  </section>

  <section id="skills" class="scroll-mt-24">
    <%= section_heading_tag(command: "cat tools.txt", title: "Skills") %>
    <div class="grid gap-6 md:grid-cols-2">
      <% SiteData.fetch(:tech_stack).each do |tech| %>
        <%= render "shared/badge_group", group: tech %>
      <% end %>
    </div>
  </section>

  <section id="work" class="scroll-mt-24">
    <%= section_heading_tag(command: "history --work", title: "Work experience") %>
    <%= work_history_tag(positions: positions) %>
  </section>

  <section id="education" class="scroll-mt-24">
    <%= section_heading_tag(command: "cat education.txt", title: "Education") %>
    <%= education_tag(schools: SiteData.fetch(:education)) %>
  </section>

  <div class="pt-4">
    <%= cli_prompt_tag("echo \"Hello, Nick!\"", classes: "mb-3") %>
    <p class="text-base-content/70 max-w-2xl mb-4">
      Hiring, collaborating, or just comparing tomato varieties — I'd like to hear from you.
    </p>
    <%= link_to "get in touch →", contact_path,
                class: "btn btn-primary btn-wide font-mono",
                data: { turbo_action: "advance" } %>
  </div>
</section>
