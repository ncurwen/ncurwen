<% content_for :title, "Experience — Nick Curwen" %>
<% featured  = SiteData.portfolio[:featured] %>
<% groups    = SiteData.tech_stack[:groups] %>
<% positions = SiteData.work_history[:positions] %>
<% schools   = SiteData.education[:schools] %>

<% work_children = positions.map { |p|
     { id: WorkHistoryComponent.anchor(p[:company]), label: p[:company] }
   } %>

<%= render TableOfContentsComponent.new(
            sections: [
              { id: "featured",  label: "Featured project" },
              { id: "skills",    label: "Skills" },
              { id: "work",      label: "Work experience", children: work_children },
              { id: "education", label: "Education" }
            ]) %>

<section class="max-w-4xl mx-auto px-4 py-12 space-y-16">
  <header id="top" class="scroll-mt-24">
    <%= cli_prompt_tag("cat resume.txt", classes: "mb-1") %>
    <h1 class="text-3xl md:text-4xl font-bold">Experience</h1>
    <p class="mt-2 text-base-content/70 max-w-2xl">
      Twelve years of building software — full-stack Rails, data pipelines and AWS
      infrastructure — for an enterprise R&amp;D shop and a handful of smaller teams.
      Side project: <a href="https://agilepanda.dev" target="_blank" rel="noopener" class="link link-primary font-mono">agilepanda.dev</a>.
      Source on <a href="https://github.com/ncurwen" target="_blank" rel="noopener" class="link link-primary font-mono">GitHub</a>.
    </p>
  </header>

  <section id="featured" class="scroll-mt-24">
    <%= section_heading_tag(command: "ls projects/", title: "Featured project", title_class: "mb-4") %>
    <%= render "shared/project_card", project: featured, featured: true %>
  </section>

  <section id="skills" class="scroll-mt-24">
    <%= section_heading_tag(command: "cat tools.txt", title: "Skills") %>
    <div class="grid gap-6 md:grid-cols-2">
      <% groups.each do |group| %>
        <%= render "shared/badge_group", group: group %>
      <% end %>
    </div>
  </section>

  <section id="work" class="scroll-mt-24">
    <%= section_heading_tag(command: "history --work", title: "Work experience") %>
    <%= render WorkHistoryComponent.new(positions: positions) %>
  </section>

  <section id="education" class="scroll-mt-24">
    <%= section_heading_tag(command: "cat education.txt", title: "Education") %>
    <%= render EducationComponent.new(schools: schools) %>
  </section>

  <div class="text-center pt-4">
    <%= link_to "get in touch →", contact_path,
                class: "btn btn-primary btn-wide font-mono",
                data: { turbo_action: "advance" } %>
  </div>
</section>
