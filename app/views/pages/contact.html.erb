<% content_for :title, "Contact — Nick Curwen" %>

<% content_for :head do %>
  <%= cloudflare_turnstile_script_tag %>
<% end %>

<section class="max-w-3xl mx-auto px-4 py-12">
  <header class="mb-10">
    <%= cli_prompt_tag("mail nick", classes: "mb-1", caret: true) %>
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">Get in touch</h1>
    <p class="mt-2 text-base-content/70">
      Hiring, collaborating, swapping seedlings — all welcome. Drop me a line with the
      form below, or reach out directly.
    </p>
  </header>

  <div class="grid gap-8 md:grid-cols-5">
    <aside class="md:col-span-2 space-y-4">
      <%= copy_tag(label: "email", value: "contact@ncurwen.dev") %>

      <% [
           { label: "github",   url: "https://github.com/ncurwen",                text: "github.com/ncurwen" },
           { label: "linkedin", url: "https://www.linkedin.com/in/nick-curwen/", text: "linkedin.com/in/nick-curwen" }
         ].each do |link| %>
        <a href="<%= link[:url] %>" target="_blank" rel="noopener"
           class="card group bg-base-200 border border-base-300 hover:bg-base-300 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
          <div class="card-body p-5 gap-2">
            <div class="flex items-center justify-between">
              <h2 class="card-title text-sm font-mono text-base-content/60 transition-colors group-hover:text-primary"><%= link[:label] %></h2>
              <%= lucide_icon "arrow-up-right", class: "w-4 h-4 text-base-content/40 transition-all duration-200 group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5", "aria-hidden": true %>
            </div>
            <span class="text-sm break-all link link-hover font-mono"><%= link[:text] %></span>
          </div>
        </a>
      <% end %>
    </aside>

    <%= form_with model: @contact_form, url: contact_path, method: :post, class: "md:col-span-3 card bg-base-200 border border-base-300" do |f| %>
      <fieldset class="fieldset card-body gap-3">
        <legend class="fieldset-legend font-mono">send a message</legend>

        <% if @contact_form.errors.any? %>
          <div role="alert" class="alert alert-error alert-soft">
            <ul class="list-disc list-inside text-sm">
              <% @contact_form.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "your name", class: "label font-mono text-xs" %>
          <%= f.text_field :name, placeholder: "grace hopper", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :email, "your email", class: "label font-mono text-xs" %>
          <%= f.email_field :email, placeholder: "you@example.com", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :subject, "subject", class: "label font-mono text-xs" %>
          <%= f.text_field :subject, placeholder: "hi nick — about...", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :message, "message", class: "label font-mono text-xs" %>
          <%= f.text_area :message, placeholder: "hello...", class: "textarea w-full h-32" %>
        </div>

        <div data-controller="cloudflare-turnstile">
          <%= cloudflare_turnstile %>
        </div>

        <div class="card-actions items-center justify-between pt-2">
          <p class="text-xs text-base-content/50 font-mono">replies in a day or two</p>
          <%= f.submit "send →", class: "btn btn-primary font-mono" %>
        </div>
      </fieldset>
    <% end %>
  </div>
</section>
