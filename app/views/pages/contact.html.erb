<% content_for :title, "Contact — Nick Curwen" %>

<section class="max-w-3xl mx-auto px-4 py-12">
  <header class="mb-10">
    <p class="font-mono text-primary text-sm mb-1">$ mail nick</p>
    <h1 class="text-3xl md:text-4xl font-bold">Get in touch</h1>
    <p class="mt-2 text-base-content/70">
      Hiring, collaborating, swapping seedlings — all welcome. Drop me a line with the
      form below, or reach me by email or GitHub.
    </p>
  </header>

  <div class="grid gap-8 md:grid-cols-5">
    <aside class="md:col-span-2 space-y-4">
      <div class="card bg-base-200">
        <div class="card-body p-5" data-controller="copy">
          <h2 class="card-title text-base font-mono">email</h2>
          <div class="flex items-center gap-2">
            <code class="text-sm break-all" data-copy-target="source">contact@ncurwen.dev</code>
            <button type="button"
                    class="btn btn-xs btn-ghost"
                    data-action="copy#copy"
                    aria-label="Copy email">
              copy
            </button>
          </div>
          <div class="toast toast-end hidden" data-copy-target="toast">
            <div role="alert" class="alert alert-success">
              <span>copied!</span>
            </div>
          </div>
        </div>
      </div>

      <div class="card bg-base-200">
        <div class="card-body p-5">
          <h2 class="card-title text-base font-mono">github</h2>
          <a href="https://github.com/ncurwen" target="_blank" rel="noopener"
             class="link link-primary font-mono break-all">
            github.com/ncurwen
          </a>
        </div>
      </div>

      <div class="card bg-base-200">
        <div class="card-body p-5">
          <h2 class="card-title text-base font-mono">linkedin</h2>
          <a href="https://www.linkedin.com/in/nick-curwen/" target="_blank" rel="noopener"
             class="link link-primary font-mono break-all">
            linkedin.com/in/nick-curwen
          </a>
        </div>
      </div>
    </aside>

    <%= form_with model: @contact_form, url: contact_path, method: :post, class: "md:col-span-3 card bg-base-200" do |f| %>
      <fieldset class="fieldset card-body gap-3">
        <legend class="fieldset-legend font-mono">send a message</legend>

        <% if @contact_form.errors.any? %>
          <div role="alert" class="alert alert-error alert-soft">
            <ul class="list-disc list-inside text-sm">
              <% @contact_form.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "your name", class: "label font-mono text-xs" %>
          <%= f.text_field :name, placeholder: "grace hopper", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :email, "your email", class: "label font-mono text-xs" %>
          <%= f.email_field :email, placeholder: "you@example.com", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :subject, "subject", class: "label font-mono text-xs" %>
          <%= f.text_field :subject, placeholder: "hi nick — about...", class: "input w-full" %>
        </div>

        <div>
          <%= f.label :message, "message", class: "label font-mono text-xs" %>
          <%= f.text_area :message, placeholder: "hello...", class: "textarea w-full h-32" %>
        </div>

        <div class="card-actions justify-end pt-2">
          <%= f.submit "send →", class: "btn btn-primary font-mono" %>
        </div>
      </fieldset>
    <% end %>
  </div>
</section>
