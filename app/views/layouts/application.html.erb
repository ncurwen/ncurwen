<!DOCTYPE html>
<html lang="en" data-theme="ncurwen-light" data-controller="theme" class="scroll-smooth">
  <head>
    <title><%= content_for(:title) || "Nick Curwen — senior software developer, tech enthusiast, gardener" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ncurwen.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Set the theme before first paint to avoid a flash of the default theme. %>
    <%# Keys/values must stay in sync with theme_controller.js. %>
    <%= javascript_tag nonce: true do %>
      (function () {
        try {
          var stored = localStorage.getItem("ncurwen-theme")
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
          document.documentElement.dataset.theme = stored || (prefersDark ? "ncurwen-dark" : "ncurwen-light")
        } catch (e) {}
      })()
    <% end %>

    <%= turbo_refreshes_with(method: :morph, scroll: :preserve) %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col bg-base-100 text-base-content">
    <%= render "layouts/nav" %>

    <main id="page-body" class="flex-1">
      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
  </body>
</html>
