<!DOCTYPE html>
<html lang="en" data-theme="<%= cookies[:light_mode] == "true" ? ThemeToggleComponent::LIGHT_THEME_NAME : ThemeToggleComponent::DARK_THEME_NAME %>">
  <head>
    <title><%= content_for(:title) || "Nick Curwen — software developer, tech enthusiast, gardener" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ncurwen.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= turbo_refreshes_with(method: :morph, scroll: :preserve) %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-dvh flex flex-col bg-base-100 text-base-content overflow-hidden">
    <%= render "layouts/nav" %>

    <%# Page content scrolls inside <main> so the header and footer sit outside
        the scrollbar's reach and span the full window width without shifting.
        scrollbar-gutter (in application.tailwind.css) keeps the inner width
        constant; its reserved strip sits beside base-100 content, so it blends. %>
    <main id="page-body" class="flex-1 overflow-y-auto scroll-smooth">
      <% if flash.any? %>
        <div class="max-w-3xl mx-auto px-4 pt-6 space-y-2">
          <% if flash[:notice] %>
            <div role="alert" class="alert alert-success alert-soft"><span><%= flash[:notice] %></span></div>
          <% end %>
          <% if flash[:alert] %>
            <div role="alert" class="alert alert-error alert-soft"><span><%= flash[:alert] %></span></div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
  </body>
</html>
