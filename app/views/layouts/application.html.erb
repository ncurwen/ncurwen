<!DOCTYPE html>
<html lang="en" data-theme="ncurwen-light" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "Nick Curwen — senior software developer, tech enthusiast, gardener" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ncurwen.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <meta name="view-transition" content="same-origin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Set the theme before first paint to avoid a flash of the default theme. %>
    <%# Keys/values must stay in sync with theme_controller.js. %>
    <%= javascript_tag nonce: true do %>
      (function () {
        try {
          var stored = localStorage.getItem("ncurwen-theme")
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
          document.documentElement.dataset.theme = stored || (prefersDark ? "ncurwen-dark" : "ncurwen-light")
        } catch (e) {}
      })()
    <% end %>

    <%= turbo_refreshes_with(method: :morph, scroll: :preserve) %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="h-dvh flex flex-col bg-base-100 text-base-content overflow-hidden">
    <%= render "layouts/nav" %>

    <%# Page content scrolls inside <main> so the header and footer sit outside
        the scrollbar's reach and span the full window width without shifting.
        scrollbar-gutter (in application.tailwind.css) keeps the inner width
        constant; its reserved strip sits beside base-100 content, so it blends. %>
    <main id="page-body" class="flex-1 overflow-y-auto scroll-smooth">
      <% if flash.any? %>
        <div class="max-w-3xl mx-auto px-4 pt-6 space-y-2">
          <% if flash[:notice] %>
            <div role="alert" class="alert alert-success alert-soft"><span><%= flash[:notice] %></span></div>
          <% end %>
          <% if flash[:alert] %>
            <div role="alert" class="alert alert-error alert-soft"><span><%= flash[:alert] %></span></div>
          <% end %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
  </body>
</html>
