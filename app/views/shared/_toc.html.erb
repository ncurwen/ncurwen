<%# locals: sections %>

<aside class="hidden xl:block fixed right-8 top-1/2 -translate-y-1/2 z-20 w-56"
       data-controller="toc"
       aria-label="Page sections">
  <p class="font-mono text-xs uppercase tracking-wider text-base-content/50 mb-3">
    <span class="text-primary">$</span> jump-to
  </p>
  <ul class="space-y-2 font-mono text-sm border-l border-base-300 pl-3">
    <% sections.each do |section| %>
      <li>
        <a href="#<%= section[:id] %>"
           data-toc-target="link"
           data-section="<%= section[:id] %>"
           class="link link-hover text-base-content/60 transition-colors">
          <%= section[:label] %>
        </a>
        <% if section[:children].present? %>
          <ul class="mt-1.5 ml-2 space-y-1.5 border-l border-base-300/60 pl-3">
            <% section[:children].each do |child| %>
              <li>
                <a href="#<%= child[:id] %>"
                   data-toc-target="link"
                   data-section="<%= child[:id] %>"
                   class="link link-hover text-base-content/60 text-xs transition-colors">
                  <%= child[:label] %>
                </a>
              </li>
            <% end %>
          </ul>
        <% end %>
      </li>
    <% end %>
  </ul>
</aside>

<div class="xl:hidden fixed bottom-6 right-6 z-30 dropdown dropdown-top dropdown-end">
  <label tabindex="0"
         class="btn btn-circle btn-primary shadow-lg"
         aria-label="Open table of contents">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h10M4 18h16"/>
    </svg>
  </label>
  <ul tabindex="0"
      class="menu menu-sm dropdown-content mb-3 p-2 shadow bg-base-200 rounded-box w-60 font-mono max-h-[70vh] overflow-y-auto">
    <li class="menu-title text-xs">
      <span class="text-primary">$</span> jump-to
    </li>
    <% sections.each do |section| %>
      <li>
        <a href="#<%= section[:id] %>"><%= section[:label] %></a>
        <% if section[:children].present? %>
          <ul>
            <% section[:children].each do |child| %>
              <li><a href="#<%= child[:id] %>" class="text-xs"><%= child[:label] %></a></li>
            <% end %>
          </ul>
        <% end %>
      </li>
    <% end %>
  </ul>
</div>
