<%# locals: project, featured: false %>
<article class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow <%= featured ? "card-lg border border-primary/40" : "card-md" %>">
  <div class="card-body">
    <div class="flex items-start justify-between gap-3">
      <h3 class="card-title font-mono">
        <span aria-hidden="true" class="text-2xl"><%= project[:emoji] %></span>
        <%= project[:name] %>
      </h3>
      <% if featured %>
        <span class="badge badge-primary badge-sm">featured</span>
      <% end %>
    </div>
    <p class="text-base-content/80"><%= project[:blurb] %></p>
    <div class="flex flex-wrap gap-1 pt-2">
      <% Array(project[:stack]).each do |tech| %>
        <span class="badge badge-soft badge-sm font-mono"><%= tech %></span>
      <% end %>
    </div>
    <% if project[:url].present? %>
      <div class="card-actions justify-end pt-2">
        <a href="<%= project[:url] %>" target="_blank" rel="noopener"
           class="btn btn-sm <%= featured ? "btn-primary" : "btn-ghost" %> font-mono">
          visit&nbsp;→
        </a>
      </div>
    <% end %>
  </div>
</article>
