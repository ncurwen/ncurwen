      </label>

      <div class="dropdown dropdown-end md:hidden">
        <label tabindex="0" class="btn btn-ghost btn-circle" aria-label="Open menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </label>
        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-40 p-2 shadow bg-base-200 rounded-box w-52 font-mono">
          <li><%= link_to "experience", experience_path, data: { turbo_action: "advance" } %></li>
          <li><%= link_to "garden",     garden_path,     data: { turbo_action: "advance" } %></li>
          <li><%= link_to "contact",    contact_path,    data: { turbo_action: "advance" } %></li>
          <li><a href="https://github.com/ncurwen" target="_blank" rel="noopener">github</a></li>
          <li><a href="https://www.linkedin.com/in/nick-curwen-33528572/" target="_blank" rel="noopener">linkedin</a></li>
        </ul>
      </div>
    </div>
  </div>
</header>
