<header id="primary-nav" data-turbo-permanent>
  <div class="navbar bg-base-200/80 backdrop-blur sticky top-0 z-30 border-b border-base-300">
    <div class="navbar-start">
      <%= link_to root_path,
                  class: "btn btn-ghost text-lg font-mono normal-case px-2",
                  data: { turbo_action: "advance" } do %>
        <span class="text-primary">~/</span><span>ncurwen</span><span class="text-primary">.dev</span>
      <% end %>
    </div>

    <div class="navbar-center hidden md:flex">
      <ul class="menu menu-horizontal gap-1 px-1 font-mono text-sm">
        <li><%= link_to "experience", experience_path, data: { turbo_action: "advance" } %></li>
        <li><%= link_to "garden",     garden_path,     data: { turbo_action: "advance" } %></li>
        <li><%= link_to "contact",    contact_path,    data: { turbo_action: "advance" } %></li>
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <a href="https://github.com/ncurwen"
         target="_blank" rel="noopener"
         class="btn btn-ghost btn-sm hidden sm:inline-flex font-mono"
         aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.73.5.78 5.46.78 11.73c0 4.97 3.22 9.18 7.7 10.67.56.1.77-.24.77-.54v-1.9c-3.13.68-3.79-1.51-3.79-1.51-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.68.08-.68 1.13.08 1.73 1.16 1.73 1.16 1 1.71 2.63 1.22 3.27.93.1-.73.39-1.22.71-1.5-2.5-.28-5.13-1.25-5.13-5.57 0-1.23.44-2.24 1.16-3.03-.12-.28-.5-1.43.11-2.98 0 0 .95-.3 3.11 1.16.9-.25 1.86-.37 2.82-.38.96 0 1.93.13 2.82.38 2.16-1.46 3.11-1.16 3.11-1.16.61 1.55.23 2.7.11 2.98.72.79 1.16 1.8 1.16 3.03 0 4.33-2.63 5.29-5.14 5.57.4.34.76 1.02.76 2.06v3.05c0 .3.2.65.78.54 4.47-1.49 7.69-5.7 7.69-10.67C23.22 5.46 18.27.5 12 .5z"/>
        </svg>
        <span class="hidden lg:inline">github</span>
      </a>

      <a href="https://www.linkedin.com/in/nick-curwen-33528572/"
         target="_blank" rel="noopener"
         class="btn btn-ghost btn-sm hidden sm:inline-flex font-mono"
         aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
        </svg>
        <span class="hidden lg:inline">linkedin</span>
      </a>

