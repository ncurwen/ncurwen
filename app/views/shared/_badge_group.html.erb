<%# locals: group %>
<div class="rounded-box border border-base-300 bg-base-200/40 p-4">
  <h3 class="font-mono text-sm uppercase tracking-wider text-base-content/60 mb-3 flex items-center gap-2">
    <span aria-hidden="true" class="inline-block w-2 h-2 rounded-full bg-secondary/70"></span>
    <%= group[:heading] %>
  </h3>
  <div class="flex flex-wrap gap-2">
    <% Array(group[:items]).each do |item| %>
      <span class="badge badge-outline font-mono"><%= item %></span>
    <% end %>
  </div>
</div>
